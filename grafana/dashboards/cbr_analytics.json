          "editorMode": "code",
          "format": "time_series",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT \r\n  rate_date as time,\r\n  CASE \r\n    WHEN currency_code = 'USD' THEN '🇺🇸 Доллар США'\r\n    WHEN currency_code = 'EUR' THEN '🇪🇺 Евро'\r\n    WHEN currency_code = 'CNY' THEN '🇨🇳 Юань'\r\n  END as metric,\r\n  exchange_rate as value\r\nFROM cbr_raw.exchange_rates \r\nWHERE currency_code IN ('USD', 'EUR', 'CNY')\r\n  AND rate_date > NOW() - INTERVAL '30 days'\r\nORDER BY rate_date",
