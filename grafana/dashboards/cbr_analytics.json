      "targets": [
        {
          "dataset": "etl_airflow",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PC704B7CDA7D5A133"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\n  e.currency_code as \"Код\",\r\n  MAX(e.currency_name) as \"Валюта\",\r\n  ROUND(STDDEV(e.exchange_rate)::numeric, 4) as \"Волатильность\",\r\n  ROUND(AVG(e.exchange_rate)::numeric, 2) as \"Средний\",\r\n  ROUND(MIN(e.exchange_rate)::numeric, 2) as \"Мин.\",\r\n  ROUND(MAX(e.exchange_rate)::numeric, 2) as \"Макс.\",\r\n  ROUND((MAX(e.exchange_rate) - MIN(e.exchange_rate)) / AVG(e.exchange_rate) * 100, 2) as \"Изменение %\",\r\n  COUNT(*) as \"Дней\"\r\nFROM cbr_raw.exchange_rates e\r\nWHERE e.rate_date > NOW() - INTERVAL '30 days'\r\nGROUP BY e.currency_code\r\nORDER BY \"Волатильность\" DESC\r\nLIMIT 10",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
